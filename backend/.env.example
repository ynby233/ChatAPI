# Admin user credentials (auto-created on startup)
CHATAPI_ADMIN_USERNAME=admin
CHATAPI_ADMIN_PASSWORD=change-me

# Optional. If omitted, the backend will generate a session secret on first startup
# and persist it in the database config table.
# CHATAPI_SESSION_SECRET=your-session-secret

# Optional: load another env file from outside the project directory.
# CHATAPI_ENV_FILE=/path/to/chatapi.env

CHATAPI_DB_PATH=./data/chatapi.sqlite3
CHATAPI_DATA_DIR=./data
CHATAPI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CHATAPI_HOST=0.0.0.0
CHATAPI_PORT=5000
# Flask debug / reloader. Keep this at 0 on servers.
# CHATAPI_DEBUG=0
# Optional: when set, Flask will also serve this frontend dist directory directly.
# Relative paths are resolved from the repository root.
# CHATAPI_WEB_DIST_DIR=./frontend/dist
# Optional: enable HTTPS directly in Flask by setting both variables.
# Relative paths are resolved from the repository root.
# CHATAPI_TLS_CERT_FILE=./certs/server.crt
# CHATAPI_TLS_KEY_FILE=./certs/server.key

# Optional SMTP configuration for sending emails
# CHATAPI_SMTP_HOST=smtp.example.com
# CHATAPI_SMTP_PORT=587
# CHATAPI_SMTP_USERNAME=
# CHATAPI_SMTP_PASSWORD=
# CHATAPI_SMTP_USE_TLS=1

# Optional shared sender address for all email providers
# CHATAPI_EMAIL_FROM=noreply@kirari.fun

# Optional Resend configuration for sending emails
# If you use Resend, replace re_xxxxxxxxx with your real API key.
# CHATAPI_RESEND_API_KEY=re_xxxxxxxxx

# Optional Brevo configuration for sending emails
# CHATAPI_BREVO_API_KEY=YOUR_BREVO_API_KEY
# Optional display name for Brevo sender.
# CHATAPI_BREVO_FROM_NAME=ChatAPI

# Optional Tencent Cloud SES configuration for sending emails
# Tencent Cloud uses SecretId / SecretKey. The sender address must be verified in SES.
# CHATAPI_TENCENTCLOUD_SECRET_ID=AKIDxxxxxxxxxxxxxxxx
# CHATAPI_TENCENTCLOUD_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional SES region. Supported regions in the Tencent Cloud SES API include ap-guangzhou and ap-hongkong.
# CHATAPI_TENCENTCLOUD_SES_REGION=ap-guangzhou
# Required for normal SES accounts unless you have a special configuration that allows simple email sending.
# CHATAPI_TENCENTCLOUD_TEMPLATE_ID=100091

# Optional GeeTest v4 captcha configuration for registration protection
# CHATAPI_GEETEST_CAPTCHA_ID=
# CHATAPI_GEETEST_CAPTCHA_KEY=
# CHATAPI_GEETEST_API_SERVER=http://gcaptcha4.geetest.com
